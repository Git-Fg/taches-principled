#!/usr/bin/env bash
# bin/claude-cli-wrapper — universal launcher for the Rust-based MCP wrapper.
#
# Resolves to the right binary for the host platform, in this order:
#   1. Prebuilt binary matching the host triple (e.g. darwin-arm64, linux-x86_64)
#   2. Cached local build at target/release/claude-cli-wrapper
#   3. Build from source via `cargo build --release` (one-time ~2-3 min cost)
#
# This eliminates the v0.17.0 binary-arch bug (Issue #10 Bug 1) where the
# shipped prebuilt was Mach-O arm64 only, causing ENOEXEC on Linux/Intel
# hosts. After this commit, every supported host either finds a matching
# prebuilt or builds from the Rust source already in the repo.
#
# Requires: cargo (Rust toolchain) on PATH for the build-from-source path.
# Install: https://rustup.rs
set -euo pipefail

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"
BUILT="$PLUGIN_ROOT/target/release/claude-cli-wrapper"
ARCH="$(uname -m)"
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
HOST_TRIPLE="${OS}-${ARCH}"
PREBUILT="$PLUGIN_ROOT/bin/claude-cli-wrapper.${HOST_TRIPLE}"

if [ -x "$PREBUILT" ]; then
  exec "$PREBUILT" "$@"
fi

if [ -x "$BUILT" ]; then
  exec "$BUILT" "$@"
fi

if ! command -v cargo >/dev/null 2>&1; then
  cat >&2 <<EOF
ERROR: claude-cli-wrapper has no prebuilt binary for ${HOST_TRIPLE} and the
Rust toolchain (cargo) is not on PATH. Install Rust from https://rustup.rs
and re-run, or build manually:

    cd "$PLUGIN_ROOT" && cargo build --release

For Linux/Intel hosts, a prebuilt is expected to ship via the
.github/workflows/release-claude-cli-wrapper.yml workflow on tag push.
EOF
  exit 1
fi

echo "Building claude-cli-wrapper from source for ${HOST_TRIPLE} (one-time, ~2-3 min on Apple Silicon; ~10-15 min on Linux/Intel)..." >&2
(cd "$PLUGIN_ROOT" && cargo build --release --quiet) || {
  echo "ERROR: cargo build failed; check the output above for details." >&2
  exit 1
fi

if [ ! -x "$BUILT" ]; then
  echo "ERROR: build completed but $BUILT is not present." >&2
  exit 1
fi

exec "$BUILT" "$@"
