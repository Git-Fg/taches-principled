{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Taches Principled Marketplace",
  "description": "Schema for taches-principled marketplace manifest",
  "type": "object",
  "required": ["name", "plugins"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Marketplace identifier (kebab-case)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "strict": {
      "type": "boolean",
      "default": false,
      "description": "Enforce strict validation of plugin metadata"
    },
    "description": {
      "type": "string",
      "maxLength": 200,
      "description": "Marketplace description for catalog display"
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Plugin identifier (kebab-case)"
          },
          "source": {
            "type": "string",
            "pattern": "^\\./",
            "description": "Relative path starting with ./"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Plugin semantic version"
          },
          "displayName": {
            "type": "string",
            "description": "Human-readable plugin name"
          },
          "author": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "email": { "type": "string", "format": "email" }
            }
          },
          "homepage": {
            "type": "string",
            "format": "uri",
            "description": "Plugin homepage URL"
          },
          "repository": {
            "type": "string",
            "format": "uri",
            "description": "Repository URL"
          },
          "license": {
            "type": "string",
            "description": "SPDX license identifier"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "description": "Plugin description for catalog display"
          },
          "keywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Categorization tags"
          }
        }
      }
    }
  }
}
